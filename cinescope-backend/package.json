{
  "name": "cinescope-backend",
  "version": "1.0.0",
  "description": "Production-ready AI-powered recommendation platform backend engine",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed:reels": "ts-node-dev --transpile-only --exit-child src/seed/reels.seed.ts",
    "admin:promote": "ts-node-dev --transpile-only --exit-child src/scripts/promoteAdmin.ts",
    "reels:metrics": "ts-node-dev --transpile-only --exit-child src/scripts/refreshReelMetrics.ts",
    "reels:backfill": "ts-node-dev --transpile-only --exit-child src/scripts/backfillReelMetadata.ts"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
